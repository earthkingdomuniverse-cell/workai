{
  "expo": {
    "name": "WorkAI",
    "slug": "workai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font"],
    "scheme": "workai",
    "experiments": {
      "typedRoutes": true
    }
  }
}
