# Environment template for local development
# Core app settings
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# API paths
API_PREFIX=/api
API_VERSION=v1

# CORS
CORS_ORIGIN=*

# JWT
JWT_SECRET=REDACTED
JWT_EXPIRES_IN=7d

# Supabase (if used)
SUPABASE_URL=REDACTED
SUPABASE_ANON_KEY=REDACTED
SUPABASE_SERVICE_ROLE_KEY=REDACTED

# AI APIs
OPENAI_API_KEY=REDACTED
NVIDIA_API_KEY=REDACTED

# Feature flags
ENABLE_MOCK_MODE=true
ENABLE_ADMIN_TAB=true
ENABLE_SWAGGER=true

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# App
APP_NAME=SkillValue AI Backend

# DB
DATABASE_URL="file:./dev.db"
