datasource db {
  provider = "sqlite"
  // URL is provided by prisma.config.ts via DATABASE_URL
}

generator client {
  provider = "prisma-client-js"
}

model Thread {
  id        String     @id
  topic     String
  status    String
  createdAt DateTime
  updatedAt DateTime
  messages  Message[]
  proposals Proposal[]
}

model Message {
  id        String   @id
  thread    Thread   @relation(fields: [threadId], references: [id])
  threadId  String
  senderId  String
  text      String
  timestamp DateTime
}

model Proposal {
  id           String   @id
  thread       Thread   @relation(fields: [threadId], references: [id])
  threadId     String
  mentorId     String
  plan         String
  price        Int?
  durationDays Int?
  status       String
  createdAt    DateTime
  updatedAt    DateTime
}
