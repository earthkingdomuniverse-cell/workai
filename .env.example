# ============================================
# WorkAI Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit .env files with real secrets!

# ============================================
# Core Application Settings
# ============================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================
# Application Info
# ============================================
APP_NAME=SkillValue AI
APP_VERSION=1.0.0
APP_URL=https://api.skillvalue.ai
API_PREFIX=/api
API_VERSION=v1

# ============================================
# Security - JWT Configuration (REQUIRED)
# Generate with: openssl rand -base64 32
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=https://skillvalue.ai,https://app.skillvalue.ai
CORS_CREDENTIALS=true

# ============================================
# Database - PostgreSQL (REQUIRED)
# Format: postgresql://user:password@host:port/database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/workai
DATABASE_POOL_SIZE=20
DATABASE_SSL_MODE=require

# ============================================
# Cache - Redis (Optional but Recommended)
# Format: redis://user:password@host:port
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# AI/ML Services
# ============================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o

# Anthropic Claude (Optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini (Optional)
GOOGLE_API_KEY=your-google-api-key

# Azure OpenAI (Optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ============================================
# Payment Processing - Stripe (Optional)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_API_VERSION=2024-06-20

# ============================================
# Email Service (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=SkillValue AI
SMTP_FROM_EMAIL=noreply@skillvalue.ai
SMTP_SECURE=true

# SendGrid Alternative (Optional)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ============================================
# File Storage (Optional)
# ============================================
# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Cloudflare R2 (Optional)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# ============================================
# Monitoring & Logging (Optional)
# ============================================
# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog (Optional)
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_STANDARD_HEADERS=true
RATE_LIMIT_LEGACY_HEADERS=false

# ============================================
# Feature Flags
# ============================================
ENABLE_SWAGGER=false
ENABLE_ADMIN_TAB=false
ENABLE_MOCK_MODE=false
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_LOGGING=true

# ============================================
# Expo / Mobile Public Configuration
# These are exposed to the mobile app
# ============================================
EXPO_PUBLIC_API_URL=https://api.skillvalue.ai/api/v1
EXPO_PUBLIC_ENABLE_MOCK_MODE=false
EXPO_PUBLIC_ENABLE_ADMIN_TAB=false
EXPO_PUBLIC_APP_NAME=SkillValue AI
EXPO_PUBLIC_SUPPORT_EMAIL=support@skillvalue.ai

# ============================================
# Development Only (Don't use in production)
# ============================================
# DEBUG=false
# VERBOSE_ERRORS=false
# DISABLE_SECURITY=false

# ============================================
# CI/CD Configuration
# ============================================
# These are set automatically in GitHub Actions
# CI=true
# GITHUB_SHA=
# GITHUB_REF=
# GITHUB_REPOSITORY=

# ============================================
# Deployment Configuration
# ============================================
DEPLOY_ENVIRONMENT=production
DEPLOY_HEALTH_CHECK_PATH=/health
DEPLOY_HEALTH_CHECK_TIMEOUT=60

# ============================================
# Documentation
# ============================================
# Required Secrets for Production:
#   - JWT_SECRET (32+ character random string)
#   - DATABASE_URL (PostgreSQL connection string)
#   - SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#
# Optional Secrets:
#   - REDIS_URL, OPENAI_API_KEY, STRIPE_SECRET_KEY
#   - SMTP_PASS, SENTRY_DSN, etc.
#
# Setup Command:
#   ./scripts/setup-github-secrets.sh
#
# Or use CI mode:
#   source .env && ./scripts/setup-github-secrets-ci.sh
# ============================================
