{
  "name": "workai-backend",
  "version": "1.0.0",
  "description": "WorkAI Backend - Marketplace, Wallet, Escrow, and Payment Infrastructure",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security-check": "audit-ci --critical",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "openai": "^6.34.0",
    "pino": "^9.3.2",
    "uuid": "^14.0.0",
    "zod": "^3.23.8",
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "eslint": "^8.57.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
