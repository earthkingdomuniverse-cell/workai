{
  "name": "skillvalue-ai-backend",
  "version": "1.0.0",
  "description": "SkillValue AI Backend - Official Product 1.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "sonar": "sonar-scanner",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security-check": "audit-ci --critical",
    "prepare": "husky",
    "swarm": "npx tsx scripts/ai-swarm.ts --providers=5 --clients=5 --cycles=3",
    "docs-serve": "npx http-server docs -p 8080",
    "build-docs-index": "node scripts/build_docs_index.js"
  },
  "keywords": [
    "skillvalue",
    "ai",
    "marketplace",
    "backend"
  ],
  "author": "SkillValue AI",
  "license": "UNLICENSED",
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "expo": "^51.0.0",
    "fastify": "^5.8.5",
    "highlight.js": "^11.8.0",
    "jose": "^6.2.2",
    "markdown-it": "^12.3.0",
    "openai": "^6.34.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.4.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "audit-ci": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "sonarqube-scanner": "^4.3.6",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
